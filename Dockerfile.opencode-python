ARG OPENCODE_IMAGE=ghcr.io/anomalyco/opencode:latest
FROM ${OPENCODE_IMAGE}

USER root
RUN if command -v apk >/dev/null 2>&1; then \
      apk add --no-cache python3 py3-pip bash git curl ca-certificates; \
    elif command -v apt-get >/dev/null 2>&1; then \
      apt-get update && \
      apt-get install -y --no-install-recommends python3 python3-pip bash git curl ca-certificates && \
      rm -rf /var/lib/apt/lists/*; \
    else \
      echo "unsupported base image package manager" >&2; exit 1; \
    fi
